---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const base = import.meta.env.BASE_URL;
const szolgaltatasok = (await getCollection('szolgaltatasok')).sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(szolgaltatasok.map(async (s) => {
  const { Content } = await render(s);
  return { ...s, Content };
}));
---

<BaseLayout title="Szolgáltatások">
  <section class="page-hero">
    <h1>Szolgáltatásaink</h1>
    <p>Komplex mozgásszervi ellátás egy helyen</p>
  </section>

  <section class="section">
    {rendered.map((service) => (
        <div class="service-detail">
          <div class="service-header">
            <span class="service-icon">{service.data.icon}</span>
            <h2>{service.data.title}</h2>
          </div>
          <div class="service-body">
            <service.Content />
          </div>
          <div class="price">
            {service.data.prices.map((p) => (
              <span>{p.label}: <strong>{p.value}</strong></span>
            ))}
          </div>
        </div>
    ))}

    <div class="cta-section">
      <p>Nem biztos benne, melyik szolgáltatás az Ön számára a legmegfelelőbb?</p>
      <a href={`${base}kapcsolat/`} class="btn btn-primary">Kérjen konzultációt</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--primary-light) 0%, #d4edda 100%);
    padding: 4rem 1.5rem 3rem;
    text-align: center;
  }

  .page-hero h1 {
    font-size: 2.4rem;
    color: var(--primary-dark);
    margin-bottom: 0.5rem;
  }

  .page-hero p {
    color: var(--text-light);
    font-size: 1.1rem;
  }

  .service-detail {
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: var(--radius);
    padding: 2.5rem;
    margin-bottom: 2rem;
    transition: box-shadow 0.2s;
  }

  .service-detail:hover {
    box-shadow: var(--shadow);
  }

  .service-header {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1rem;
  }

  .service-icon {
    font-size: 2rem;
  }

  .service-header h2 {
    color: var(--primary-dark);
    font-size: 1.6rem;
  }

  .service-body {
    color: var(--text-light);
    margin-bottom: 1.5rem;
  }

  .service-body :global(ul) {
    list-style: none;
    padding: 0;
  }

  .service-body :global(li) {
    padding: 0.3rem 0 0.3rem 1.5rem;
    position: relative;
    color: var(--text);
  }

  .service-body :global(li::before) {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--primary);
    font-weight: bold;
  }

  .price {
    background: var(--primary-light);
    padding: 1rem 1.5rem;
    border-radius: 8px;
    font-size: 0.95rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 2rem;
  }

  .cta-section {
    text-align: center;
    padding: 2rem;
    background: var(--bg-alt);
    border-radius: var(--radius);
  }

  .cta-section p {
    margin-bottom: 1rem;
    font-size: 1.1rem;
    color: var(--text);
  }

  .btn {
    padding: 0.85rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s;
    display: inline-block;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--primary);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--primary-dark);
  }
</style>
