---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const base = import.meta.env.BASE_URL;
const szobak = (await getCollection('szobak')).sort((a, b) => a.data.order - b.data.order);
const renderedRooms = await Promise.all(szobak.map(async (r) => {
  const { Content } = await render(r);
  return { ...r, Content };
}));
---

<BaseLayout title="Szobabérlés">
  <section class="page-hero">
    <h1>Szobabérlés</h1>
    <p>Modern, felszerelt kezelőszobák gyógytornászoknak és terapeutáknak</p>
  </section>

  <section class="section">
    <p class="intro">Kezelőszobáinkat gyógytornászok, fizioterapeuták, masszőrök és egyéb terapeuta szakemberek számára kínáljuk bérbeadásra. Minden szoba teljesen felszerelt, azonnal használatba vehető.</p>

    <div class="rooms-grid">
      {renderedRooms.map((room, i) => (
          <div class="room-card">
            <div class="room-image">
              <div class="room-placeholder">{room.data.icon}</div>
            </div>
            <div class="room-info">
              <h2>{i + 1}. szoba - {room.data.title}</h2>
              <span class="room-size">{room.data.size}</span>
              <div class="room-desc"><room.Content /></div>
              <h4>Felszereltség:</h4>
              <ul>
                {room.data.equipment.map((item) => <li>{item}</li>)}
              </ul>
              <div class="room-pricing">
                <div class="price-item">
                  <span class="price-label">Óradíj</span>
                  <span class="price-value">{room.data.prices.hourly}</span>
                </div>
                <div class="price-item">
                  <span class="price-label">Napi díj</span>
                  <span class="price-value">{room.data.prices.daily}</span>
                </div>
                <div class="price-item">
                  <span class="price-label">Havi bérlés</span>
                  <span class="price-value">{room.data.prices.monthly}</span>
                </div>
              </div>
            </div>
          </div>
      ))}
    </div>

    <div class="common-features">
      <h2>Közös szolgáltatások</h2>
      <div class="features-list">
        <div class="feature-item">📶 Nagysebességű Wi-Fi</div>
        <div class="feature-item">🚿 Közös zuhanyzó</div>
        <div class="feature-item">☕ Konyha és pihenő</div>
        <div class="feature-item">🧹 Napi takarítás</div>
        <div class="feature-item">🔑 Önálló kulcsos bejárás</div>
        <div class="feature-item">♿ Akadálymentes megközelítés</div>
      </div>
    </div>

    <div class="cta-section">
      <p>Érdekli valamelyik szobánk? Vegye fel velünk a kapcsolatot!</p>
      <a href={`${base}kapcsolat/`} class="btn btn-primary">Érdeklődés</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--primary-light) 0%, #d4edda 100%);
    padding: 4rem 1.5rem 3rem;
    text-align: center;
  }

  .page-hero h1 {
    font-size: 2.4rem;
    color: var(--primary-dark);
    margin-bottom: 0.5rem;
  }

  .page-hero p {
    color: var(--text-light);
    font-size: 1.1rem;
  }

  .intro {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 3rem;
    color: var(--text-light);
    font-size: 1.05rem;
  }

  .rooms-grid {
    display: grid;
    gap: 2rem;
  }

  .room-card {
    display: grid;
    grid-template-columns: 200px 1fr;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: var(--radius);
    overflow: hidden;
    transition: box-shadow 0.2s;
  }

  .room-card:hover {
    box-shadow: var(--shadow);
  }

  .room-image {
    background: var(--bg-alt);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .room-placeholder {
    font-size: 3rem;
  }

  .room-info {
    padding: 2rem;
  }

  .room-info h2 {
    color: var(--primary-dark);
    margin-bottom: 0.3rem;
    font-size: 1.4rem;
  }

  .room-size {
    display: inline-block;
    background: var(--primary-light);
    color: var(--primary-dark);
    padding: 0.2rem 0.8rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .room-desc {
    color: var(--text-light);
    margin-bottom: 1rem;
  }

  .room-info h4 {
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .room-info ul {
    list-style: none;
    margin-bottom: 1.5rem;
    padding: 0;
  }

  .room-info li {
    padding: 0.2rem 0 0.2rem 1.5rem;
    position: relative;
    font-size: 0.95rem;
  }

  .room-info li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--primary);
    font-weight: bold;
  }

  .room-pricing {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .price-item {
    background: var(--bg-alt);
    padding: 0.8rem 1.2rem;
    border-radius: 8px;
    text-align: center;
  }

  .price-label {
    display: block;
    font-size: 0.8rem;
    color: var(--text-light);
  }

  .price-value {
    display: block;
    font-weight: 700;
    color: var(--primary-dark);
    font-size: 1.05rem;
  }

  .common-features {
    margin-top: 3rem;
    padding: 2.5rem;
    background: var(--bg-alt);
    border-radius: var(--radius);
  }

  .common-features h2 {
    text-align: center;
    color: var(--primary-dark);
    margin-bottom: 1.5rem;
  }

  .features-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .feature-item {
    padding: 0.5rem;
    font-size: 1rem;
  }

  .cta-section {
    text-align: center;
    padding: 2rem;
    margin-top: 2rem;
    background: var(--bg-alt);
    border-radius: var(--radius);
  }

  .cta-section p {
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  .btn {
    padding: 0.85rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s;
    display: inline-block;
    text-decoration: none;
  }

  .btn-primary { background: var(--primary); color: #fff; }
  .btn-primary:hover { background: var(--primary-dark); }

  @media (max-width: 768px) {
    .room-card { grid-template-columns: 1fr; }
    .room-image { min-height: 100px; }
  }
</style>
