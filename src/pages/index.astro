---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Főoldal">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <h1>Gyógyuljon meg velünk,<br/>mozogjon szabadon!</h1>
      <p>Professzionális gyógytorna, mozgásterápia és rehabilitáció Budapest szívében, a Széll Kálmán térnél.</p>
      <div class="hero-buttons">
        <a href={`${base}kapcsolat/`} class="btn btn-primary">Időpontfoglalás</a>
        <a href={`${base}szolgaltatasok/`} class="btn btn-outline">Szolgáltatásaink</a>
      </div>
    </div>
  </section>

  <!-- Szolgáltatások áttekintés -->
  <section class="section" id="services-overview">
    <h2 class="section-title">Szolgáltatásaink</h2>
    <p class="section-subtitle">Egyénre szabott kezelések tapasztalt szakemberekkel</p>
    <div class="services-grid">
      <div class="service-card">
        <div class="service-icon">🦴</div>
        <h3>Gerincterápia</h3>
        <p>Gerincproblémák komplex kezelése, fájdalomcsillapítás és tartásjavítás modern módszerekkel.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">🏃</div>
        <h3>Mozgásterápia</h3>
        <p>Személyre szabott mozgásprogramok a mindennapi mozgásminőség javítására.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">💪</div>
        <h3>Rehabilitáció</h3>
        <p>Műtét utáni és sérülés utáni rehabilitáció szakszerű felügyelettel.</p>
      </div>
      <div class="service-card">
        <div class="service-icon">🧘</div>
        <h3>Csoportos torna</h3>
        <p>Kiscsoportos foglalkozások gerincre, tartásra és általános erőnlétre.</p>
      </div>
    </div>
  </section>

  <!-- Miért minket -->
  <section class="section why-us">
    <h2 class="section-title">Miért a MozgásKözpontot?</h2>
    <p class="section-subtitle">Amit kínálunk</p>
    <div class="features-grid">
      <div class="feature">
        <span class="feature-number">10+</span>
        <span class="feature-label">év tapasztalat</span>
      </div>
      <div class="feature">
        <span class="feature-number">6</span>
        <span class="feature-label">szakember</span>
      </div>
      <div class="feature">
        <span class="feature-number">4</span>
        <span class="feature-label">kezelőszoba</span>
      </div>
      <div class="feature">
        <span class="feature-number">2000+</span>
        <span class="feature-label">elégedett páciens</span>
      </div>
    </div>
  </section>

  <!-- Szobabérlés CTA -->
  <section class="section rooms-cta">
    <div class="cta-box">
      <h2>Terapeuta vagy gyógytornász?</h2>
      <p>Bérelje ki modern, felszerelt kezelőszobáinkat óra-, nap- vagy havi alapon. Központi helyszín a Széll Kálmán térnél.</p>
      <a href={`${base}szobak/`} class="btn btn-primary">Szobáink megtekintése</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--primary-light) 0%, #d4edda 100%);
    padding: 6rem 1.5rem 5rem;
    text-align: center;
  }

  .hero-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .hero h1 {
    font-size: 2.8rem;
    color: var(--primary-dark);
    margin-bottom: 1.2rem;
    font-weight: 800;
  }

  .hero p {
    font-size: 1.2rem;
    color: var(--text-light);
    margin-bottom: 2rem;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.85rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s;
    display: inline-block;
    cursor: pointer;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--primary);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--primary-dark);
  }

  .btn-outline {
    border: 2px solid var(--primary);
    color: var(--primary);
    background: transparent;
  }

  .btn-outline:hover {
    background: var(--primary);
    color: #fff;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    background: var(--bg);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: var(--radius);
    padding: 2rem;
    text-align: center;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .service-card:hover {
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  .service-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .service-card h3 {
    margin-bottom: 0.5rem;
    color: var(--primary-dark);
  }

  .service-card p {
    color: var(--text-light);
    font-size: 0.95rem;
  }

  .why-us {
    background: var(--bg-alt);
    max-width: none;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 2rem;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .feature-number {
    display: block;
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--primary);
  }

  .feature-label {
    color: var(--text-light);
    font-size: 1rem;
  }

  .cta-box {
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: #fff;
    border-radius: var(--radius);
    padding: 3rem;
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-box h2 {
    margin-bottom: 1rem;
  }

  .cta-box p {
    margin-bottom: 1.5rem;
    opacity: 0.9;
  }

  .cta-box .btn-primary {
    background: #fff;
    color: var(--primary-dark);
  }

  .cta-box .btn-primary:hover {
    background: var(--primary-light);
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2rem;
    }
  }
</style>
