---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;
const dateFormatted = new Date(post.data.date).toLocaleDateString('hu-HU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={post.data.title}>
  <article class="article">
    <header class="article-header">
      <a href={`${base}blog/`} class="back-link">&larr; Vissza a bloghoz</a>
      <h1>{post.data.title}</h1>
      <div class="article-meta">
        <time>{dateFormatted}</time>
        <span class="author">{post.data.author}</span>
      </div>
      {post.data.tags?.length ? (
        <div class="article-tags">
          {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      ) : null}
    </header>

    <div class="article-body">
      <Content />
    </div>

    <footer class="article-footer">
      <p>Kérdése van? <a href={`${base}kapcsolat/`}>Vegye fel velünk a kapcsolatot!</a></p>
    </footer>
  </article>
</BaseLayout>

<style>
  .article {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .back-link {
    display: inline-block;
    color: var(--primary);
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  .article-header h1 {
    font-size: 2.2rem;
    color: var(--primary-dark);
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .article-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.9rem;
    color: var(--text-light);
    margin-bottom: 1rem;
  }

  .author {
    color: var(--primary);
    font-weight: 500;
  }

  .article-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--primary-light);
    color: var(--primary-dark);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .article-body {
    line-height: 1.8;
    color: var(--text);
  }

  .article-body :global(h2) {
    font-size: 1.4rem;
    color: var(--primary-dark);
    margin-top: 2rem;
    margin-bottom: 0.8rem;
  }

  .article-body :global(h3) {
    font-size: 1.15rem;
    color: var(--text);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .article-body :global(p) {
    margin-bottom: 1rem;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .article-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .article-body :global(strong) {
    color: var(--text);
  }

  .article-body :global(em) {
    color: var(--primary);
    font-style: italic;
  }

  .article-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(0,0,0,0.08);
    text-align: center;
    color: var(--text-light);
  }

  .article-footer a {
    color: var(--primary);
    font-weight: 500;
  }
</style>
