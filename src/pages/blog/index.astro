---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const posts = (await getCollection('blog')).sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Blog">
  <section class="page-hero">
    <h1>Blog</h1>
    <p>Szakmai cikkek, gyakorlattippek és hasznos tanácsok</p>
  </section>

  <section class="section">
    <div class="posts-grid">
      {posts.map((post) => (
        <a href={`${base}blog/${post.id}/`} class="post-card">
          <div class="post-meta">
            <time>{new Date(post.data.date).toLocaleDateString('hu-HU', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            <span class="post-author">{post.data.author}</span>
          </div>
          <h2>{post.data.title}</h2>
          <p>{post.data.excerpt}</p>
          {post.data.tags?.length ? (
            <div class="post-tags">
              {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          ) : null}
          <span class="read-more">Tovább olvasom &rarr;</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--primary-light) 0%, #d4edda 100%);
    padding: 4rem 1.5rem 3rem;
    text-align: center;
  }

  .page-hero h1 {
    font-size: 2.4rem;
    color: var(--primary-dark);
    margin-bottom: 0.5rem;
  }

  .page-hero p {
    color: var(--text-light);
    font-size: 1.1rem;
  }

  .posts-grid {
    display: grid;
    gap: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .post-card {
    display: block;
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: var(--radius);
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, transform 0.2s;
  }

  .post-card:hover {
    box-shadow: var(--shadow);
    transform: translateY(-2px);
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.8rem;
    font-size: 0.85rem;
    color: var(--text-light);
  }

  .post-author {
    color: var(--primary);
    font-weight: 500;
  }

  .post-card h2 {
    font-size: 1.4rem;
    color: var(--primary-dark);
    margin-bottom: 0.6rem;
  }

  .post-card p {
    color: var(--text-light);
    font-size: 0.95rem;
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .post-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .tag {
    background: var(--primary-light);
    color: var(--primary-dark);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .read-more {
    color: var(--primary);
    font-weight: 600;
    font-size: 0.9rem;
  }
</style>
