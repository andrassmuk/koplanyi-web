---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Csapatunk">
  <section class="page-hero">
    <h1>Csapatunk</h1>
    <p>Tapasztalt és elkötelezett szakemberek</p>
  </section>

  <section class="section">
    <div class="team-grid">
      <div class="team-card">
        <div class="team-avatar">KA</div>
        <h3>Dr. Kovács Anna</h3>
        <span class="role">Vezető gyógytornász</span>
        <p>12 év tapasztalat gerincterápiában és mozgásszervi rehabilitációban. Specialitása a porckorongsérv konzervatív kezelése.</p>
        <div class="specialties">
          <span>Gerincterápia</span>
          <span>Rehabilitáció</span>
        </div>
      </div>

      <div class="team-card">
        <div class="team-avatar">NP</div>
        <h3>Nagy Péter</h3>
        <span class="role">Gyógytornász, manuálterapeuta</span>
        <p>Sportolók kezelésére specializálódott. Korábban válogatott sportolók rehabilitációjában vett részt.</p>
        <div class="specialties">
          <span>Sportrehabilitáció</span>
          <span>Manuálterápia</span>
        </div>
      </div>

      <div class="team-card">
        <div class="team-avatar">SÉ</div>
        <h3>Szabó Éva</h3>
        <span class="role">Gyógytornász</span>
        <p>Várandós- és szülés utáni tornára, valamint senior rehabilitációra specializálódott szakember.</p>
        <div class="specialties">
          <span>Várandós torna</span>
          <span>Senior torna</span>
        </div>
      </div>

      <div class="team-card">
        <div class="team-avatar">TM</div>
        <h3>Tóth Márk</h3>
        <span class="role">Fizioterapeuta</span>
        <p>Funkcionális mozgásfelmérés és korrekciós gyakorlatok specialistája. FMS tanúsítvánnyal rendelkezik.</p>
        <div class="specialties">
          <span>Mozgásterápia</span>
          <span>FMS</span>
        </div>
      </div>

      <div class="team-card">
        <div class="team-avatar">HK</div>
        <h3>Horváth Kata</h3>
        <span class="role">Gyógytornász</span>
        <p>Csoportos foglalkozások vezetője. Gerinctorna és tartásjavító programok kidolgozója.</p>
        <div class="specialties">
          <span>Csoportos torna</span>
          <span>Tartásjavítás</span>
        </div>
      </div>

      <div class="team-card">
        <div class="team-avatar">BL</div>
        <h3>Balogh László</h3>
        <span class="role">Masszőr, manuálterapeuta</span>
        <p>Gyógymasszőr és manuálterapeuta, a lágyrész technikák és trigger pont terápia specialistája.</p>
        <div class="specialties">
          <span>Masszázs</span>
          <span>Trigger pont</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--primary-light) 0%, #d4edda 100%);
    padding: 4rem 1.5rem 3rem;
    text-align: center;
  }

  .page-hero h1 {
    font-size: 2.4rem;
    color: var(--primary-dark);
    margin-bottom: 0.5rem;
  }

  .page-hero p {
    color: var(--text-light);
    font-size: 1.1rem;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .team-card {
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: var(--radius);
    padding: 2rem;
    text-align: center;
    transition: box-shadow 0.2s;
  }

  .team-card:hover {
    box-shadow: var(--shadow);
  }

  .team-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 auto 1rem;
  }

  .team-card h3 {
    color: var(--text);
    margin-bottom: 0.3rem;
  }

  .role {
    color: var(--primary);
    font-size: 0.9rem;
    font-weight: 500;
    display: block;
    margin-bottom: 1rem;
  }

  .team-card p {
    color: var(--text-light);
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .specialties {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .specialties span {
    background: var(--primary-light);
    color: var(--primary-dark);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
  }
</style>
